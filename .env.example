# Site URL (for SEO, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=https://ycomp.ua

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Database (PostgreSQL)
# For Neon/Supabase: use pooled connection URL
DATABASE_URL=postgresql://user:password@host:5432/dbname?pgbouncer=true
# For migrations: use direct connection URL (without pgbouncer)
DIRECT_DATABASE_URL=postgresql://user:password@host:5432/dbname

# Upstash Redis (for rate limiting in production)
# Get from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob (для завантаження фото в адмінці)
# Автоматично додається при створенні Blob store в Vercel → Storage
BLOB_READ_WRITE_TOKEN=

# JWT secret for sessions
JWT_SECRET=

# Sentry error tracking (https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Nova Poshta API (https://novaposhta.ua)
NP_API_KEY=
NP_SENDER_REF=
NP_SENDER_PHONE=

# Telegram Bot (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# SendGrid Email (https://sendgrid.com)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@ycomp.ua

# Turbosms SMS (https://turbosms.ua)
TURBOSMS_LOGIN=
TURBOSMS_PASSWORD=
TURBOSMS_SENDER=YComp
