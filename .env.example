# Site URL (for SEO, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=https://ycomp.ua

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Database
DATABASE_URL=

# Vercel Blob (для завантаження фото в адмінці)
# Автоматично додається при створенні Blob store в Vercel → Storage
BLOB_READ_WRITE_TOKEN=

# JWT secret for sessions
JWT_SECRET=
